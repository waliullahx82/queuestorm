# Copy to .env.local for local dev. NEVER commit real values.
# In production, set these in the Vercel dashboard
# (Project -> Settings -> Environment Variables), not in any file.

# REQUIRED: personal Google AI Studio key (https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# Optional (safe defaults exist in code):
# GEMINI_MODEL=gemini-3.5-flash          # primary model (tried first)
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash # used if primary 503/429s
# LLM_RETRIES=1                          # attempts per model before failover
# LLM_TIMEOUT_MS=25000                   # hard budget; on timeout -> rules + review
# USE_LLM=true                           # set "false" to run as a pure rules service
